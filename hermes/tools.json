{
  "version": "1.0",
  "tools": [
    {"type":"function","function":{"name":"subscription_search","description":"Search subscriptions by name.","parameters":{"type":"object","properties":{"query":{"type":"string"},"include_archived":{"type":"boolean","default":false}},"additionalProperties":false}}},
    {"type":"function","function":{"name":"subscription_get","description":"Get complete subscription details.","parameters":{"type":"object","properties":{"subscription_id":{"type":"string","format":"uuid"}},"required":["subscription_id"],"additionalProperties":false}}},
    {"type":"function","x-confirmation-required":true,"function":{"name":"subscription_create","description":"Create a subscription after confirmation.","parameters":{"type":"object","properties":{"name":{"type":"string"},"vendor":{"type":"string"},"status":{"type":"string","enum":["trial","active"]},"billing_plan":{"$ref":"#/$defs/billing_plan"},"service_dates":{"$ref":"#/$defs/service_dates"}},"required":["name","status","billing_plan"],"additionalProperties":false}}},
    {"type":"function","x-confirmation-required":true,"function":{"name":"subscription_update","description":"Update a subscription using optimistic locking after confirmation.","parameters":{"type":"object","properties":{"subscription_id":{"type":"string","format":"uuid"},"expected_version":{"type":"integer","minimum":1},"name":{"type":"string"},"vendor":{"type":["string","null"]},"billing_plan":{"$ref":"#/$defs/billing_plan"},"service_dates":{"$ref":"#/$defs/service_dates"}},"required":["subscription_id","expected_version"],"additionalProperties":false}}},
    {"type":"function","x-confirmation-required":true,"function":{"name":"subscription_transition","description":"Record or withdraw a planned cancellation after confirmation; this never cancels the vendor account.","parameters":{"type":"object","properties":{"subscription_id":{"type":"string","format":"uuid"},"expected_version":{"type":"integer","minimum":1},"target_status":{"type":"string","enum":["pending_cancel","active"]},"reason":{"type":"string","minLength":1,"maxLength":500},"service_expiry_date":{"type":"string","format":"date"}},"required":["subscription_id","expected_version","target_status","reason"],"allOf":[{"if":{"properties":{"target_status":{"const":"pending_cancel"}}},"then":{"required":["service_expiry_date"]}}],"additionalProperties":false}}},
    {"type":"function","x-confirmation-required":true,"function":{"name":"subscription_archive","description":"Archive a subscription after confirmation.","parameters":{"type":"object","properties":{"subscription_id":{"type":"string","format":"uuid"}},"required":["subscription_id"],"additionalProperties":false}}},
    {"type":"function","x-confirmation-required":true,"function":{"name":"payment_record","description":"Record a payment after confirming reconciliation and schedule advancement.","parameters":{"type":"object","properties":{"subscription_id":{"type":"string","format":"uuid"},"amount":{"type":"string","pattern":"^[0-9]+(\\.[0-9]+)?$"},"currency":{"type":"string","pattern":"^[A-Z]{3}$"},"paid_at":{"type":"string","format":"date-time"},"tax_amount":{"type":"string"},"notes":{"type":"string"},"billing_event_id":{"type":"string","format":"uuid"},"advance_schedule":{"type":"boolean"}},"required":["subscription_id","amount","currency","paid_at","advance_schedule"],"additionalProperties":false}}},
    {"type":"function","function":{"name":"upcoming_events","description":"List planned events in the next number of days.","parameters":{"type":"object","properties":{"days":{"type":"integer","minimum":1,"maximum":366,"default":30},"event_types":{"type":"array","items":{"type":"string","enum":["billing","trial_end","service_expiry","cancellation_deadline","contract_end"]},"uniqueItems":true}},"additionalProperties":false}}},
    {"type":"function","function":{"name":"analytics_summary","description":"Get expected and actual totals, optionally retaining selected currencies.","parameters":{"type":"object","properties":{"currencies":{"type":"array","items":{"type":"string","pattern":"^[A-Z]{3}$"},"uniqueItems":true}},"additionalProperties":false}}}
  ],
  "$defs": {
    "billing_plan":{"type":"object","properties":{"amount":{"type":"string"},"currency":{"type":"string","pattern":"^[A-Z]{3}$"},"interval_unit":{"type":"string","enum":["day","week","month","year"]},"interval_count":{"type":"integer","minimum":1,"maximum":120},"anchor_date":{"type":"string","format":"date"},"next_billing_date":{"type":["string","null"],"format":"date"},"auto_renew":{"type":"boolean"},"billing_mode":{"type":"string","enum":["fixed","usage_based","one_time","free"]}},"required":["amount","currency","interval_unit","interval_count","anchor_date","auto_renew","billing_mode"],"additionalProperties":false},
    "service_dates":{"type":"object","properties":{"trial_end_date":{"type":["string","null"],"format":"date"},"service_expiry_date":{"type":["string","null"],"format":"date"},"cancellation_deadline":{"type":["string","null"],"format":"date"},"contract_end_date":{"type":["string","null"],"format":"date"}},"additionalProperties":false}
  }
