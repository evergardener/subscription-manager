# Bundled PostgreSQL production configuration.
# Copy outside version control to .env and protect it with mode 0600.

# latest follows the newest successful main build. Use sha-<40-character commit>
# for a reproducible deployment and rollback.
IMAGE_TAG=latest

LOG_LEVEL=INFO
POSTGRES_DB=subscription_manager
POSTGRES_USER=subscription_manager
POSTGRES_PASSWORD=replace-with-a-url-safe-random-password

# Frontend is the only published service. Point a user-managed HTTPS reverse
# proxy at this loopback endpoint.
SERVICE_BIND_ADDRESS=127.0.0.1
SERVICE_PORT=8080

SESSION_ABSOLUTE_HOURS=168
SESSION_IDLE_MINUTES=60
API_RATE_LIMIT_PER_MINUTE=300
LOGIN_RATE_LIMIT_PER_MINUTE=5

# external delegates final delivery to Hermes; disabled creates no reminder Outbox.
NOTIFICATION_MODE=external
SCHEDULER_HEARTBEAT_SECONDS=60
REMINDER_SCAN_INTERVAL_MINUTES=5
REMINDER_SCAN_DAYS=30
REMINDER_GRACE_DAYS=3
REMINDER_MAX_ATTEMPTS=5
REMINDER_LEASE_SECONDS=120
