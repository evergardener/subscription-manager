# External PostgreSQL 16+ production configuration.
# URL-encode reserved characters in credentials and require TLS as supported by
# the selected provider. Never commit the populated file.

LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://subscription_manager:replace-me@database.example.com:5432/subscription_manager?sslmode=require

SERVICE_BIND_ADDRESS=127.0.0.1
SERVICE_PORT=8080

SESSION_ABSOLUTE_HOURS=168
SESSION_IDLE_MINUTES=60
API_RATE_LIMIT_PER_MINUTE=300
LOGIN_RATE_LIMIT_PER_MINUTE=5

NOTIFICATION_MODE=external
SCHEDULER_HEARTBEAT_SECONDS=60
REMINDER_SCAN_INTERVAL_MINUTES=5
REMINDER_SCAN_DAYS=30
REMINDER_GRACE_DAYS=3
REMINDER_MAX_ATTEMPTS=5
REMINDER_LEASE_SECONDS=120
