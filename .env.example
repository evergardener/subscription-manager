ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://hermes:change-me@db:5432/hermes
POSTGRES_DB=hermes
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me
SCHEDULER_HEARTBEAT_SECONDS=60
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=replace-me
COOKIE_SECURE=false
API_RATE_LIMIT_PER_MINUTE=300
LOGIN_RATE_LIMIT_PER_MINUTE=10
HERMES_DOMAIN=subscriptions.example.com
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt
REMINDER_SCAN_DAYS=30
REMINDER_GRACE_DAYS=3
REMINDER_MAX_ATTEMPTS=5
REMINDER_LEASE_SECONDS=120
